# Copy this file to .env.deploy and fill in production values.
# .env.deploy is ignored by git.

# Public HTTPS hostname served by nginx.
BOOKMARKS_DOMAIN := bookmarks.example.com

# SSH target. This can be an ~/.ssh/config alias, such as "mysite".
BOOKMARKS_DEPLOY_HOST := mysite

# Optional: public URL used after deploy for verification.
BOOKMARKS_URL := https://$(BOOKMARKS_DOMAIN)

# Optional: set only when BOOKMARKS_DEPLOY_HOST does not already include a user
# and your SSH config does not set one.
# BOOKMARKS_DEPLOY_USER := root
